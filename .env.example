# ── Storage paths ─────────────────────────────────────────────────────────────
BRAINVAULT_DATA_DIR=./runtime
BRAINVAULT_VAULT_DIR=./vault
BACKUP_DIR=./backups

# ── API server ─────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO

# ── Web app ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Telegram bot ──────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=change-me

# ── Database (Postgres) ────────────────────────────────────────────────────────
# Leave blank to use local JSON file storage
DATABASE_URL=
# Example for Docker Compose:
# DATABASE_URL=postgresql://brainvault:brainvault@localhost:5432/brainvault

# ── Object storage (S3/MinIO) ──────────────────────────────────────────────────
# OBJECT_STORAGE_BACKEND=local   (default — saves to runtime/object_store/)
# OBJECT_STORAGE_BACKEND=s3      (requires S3_* vars below)
OBJECT_STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_NAME=brainvault
S3_REGION=us-east-1

# ── Redis queue ────────────────────────────────────────────────────────────────
# Leave blank to use local file queue (runtime/jobs/queued/)
REDIS_URL=
# Example: REDIS_URL=redis://localhost:6379/0
BRAINVAULT_QUEUE_NAME=brainvault:jobs
WORKER_POLL_TIMEOUT_S=5

# ── API key auth ───────────────────────────────────────────────────────────────
API_KEY_REQUIRED=false
# Comma-separated list of valid API keys
API_KEYS=

# ── JWT session auth (web/desktop) ────────────────────────────────────────────
JWT_AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Comma-separated user:password pairs (plain text — use a proper store in production)
BRAINVAULT_USERS=admin:changeme

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
# Default: 100/minute per IP

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_MAX_ATTEMPTS=5
BRAINVAULT_MAX_UPLOAD_BYTES=104857600   # 100 MB
